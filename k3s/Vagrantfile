Vagrant.configure("2") do |config|
  config.vm.box = "amazonlinux2"
  config.vm.provider "virtualbox" do |vb|
    vb.cpus = 2
  end

  config.vm.define "k3s-server" do |server|
    server.vm.hostname = "k3s-server"
    server.vm.network "private_network", ip: "192.168.56.10"
    
    server.vm.network "forwarded_port", guest: 6443, host: 6443
    server.vm.network "forwarded_port", guest: 80, host: 8081
    server.vm.network "forwarded_port", guest: 443, host: 8443
    server.vm.network "forwarded_port", guest: 9090, host: 9091
    server.vm.network "forwarded_port", guest: 3000, host: 3001
	  server.vm.network "forwarded_port", guest: 8090, host: 8091

    server.vm.provider "virtualbox" do |vb|
      vb.memory = "2048"
      vb.name = "k3s-server"
    end

    server.vm.disk :disk, size: "50GB", name: "zfs_pool"

    server.vm.provision "shell", inline: <<-SHELL
      systemctl stop firewalld 2>/dev/null || true
      systemctl disable firewalld 2>/dev/null || true
      systemctl stop iptables 2>/dev/null || true
      systemctl disable iptables 2>/dev/null || true

      amazon-linux-extras install -y epel
      yum install -y zfs
      modprobe zfs

      zpool create -f \
          -o ashift=12 \
          -O atime=off \
          -O compression=lz4 \
          -O xattr=sa \
          data-pool /dev/sdb

      zfs create -o mountpoint=/exports/nlp_models data-pool/nlp-models
      zfs create -o mountpoint=/exports/nlp_data data-pool/nlp-data
      zfs create -o mountpoint=/exports/localstack_data data-pool/localstack
      zfs create -o mountpoint=/exports/postgres_backup data-pool/postgres-backup
      zfs create -o mountpoint=/exports/app_static data-pool/app-static

      chmod 777 /exports
      curl -sfL https://get.k3s.io | sh -

      mkdir -p /vagrant/tokens
      cp /var/lib/rancher/k3s/server/node-token /vagrant/tokens/node-token
      chmod 644 /vagrant/tokens/node-token

      mkdir -p /home/ec2-user/.kube
      cp /etc/rancher/k3s/k3s.yaml /home/ec2-user/.kube/config
      chown -R ec2-user:ec2-user /home/ec2-user/.kube
      echo "export KUBECONFIG=/home/ec2-user/.kube/config" >> /home/ec2-user/.bashrc
      echo "alias k='kubectl'" >> /home/ec2-user/.bashrc

      curl -fsSL -o get_helm.sh https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3
      chmod 700 get_helm.sh
      ./get_helm.sh

      kubectl label node k3s-server node-role.kubernetes.io/storage=true --overwrite

      echo "Server setup complete!"
    SHELL
  end

  config.vm.define "k3s-agent1" do |agent|
    agent.vm.hostname = "k3s-agent1"
    agent.vm.network "private_network", ip: "192.168.56.11"

    agent.vm.provider "virtualbox" do |vb|
		  vb.memory = "4096"
		  vb.cpus = 2
		  vb.name = "k3s-agent1"
    end

    agent.vm.provision "shell", inline: <<-SHELL
      # 1. ОТКЛЮЧАЕМ FIREWALL
      systemctl stop firewalld 2>/dev/null || true
      systemctl disable firewalld 2>/dev/null || true
      systemctl stop iptables 2>/dev/null || true
      systemctl disable iptables 2>/dev/null || true

      # 2. БАЗОВЫЕ ПАКЕТЫ
      yum update -y
      yum install -y curl wget

      # 3. ЖДЕМ ТОКЕН
      while [ ! -f /vagrant/tokens/node-token ]; do
        echo "Waiting for node-token..."
        sleep 5
      done

      TOKEN=$(cat /vagrant/tokens/node-token)

      curl -sfL https://get.k3s.io | K3S_URL=https://192.168.56.10:6443 K3S_TOKEN=$TOKEN sh -

      echo "Agent1 setup complete!"
    SHELL
  end

  config.vm.define "k3s-agent2" do |agent|
    agent.vm.hostname = "k3s-agent2"
    agent.vm.network "private_network", ip: "192.168.56.12"

    agent.vm.provider "virtualbox" do |vb|
		  vb.memory = "2048"
		  vb.cpus = 1
		  vb.name = "k3s-agent2"
    end

    agent.vm.provision "shell", inline: <<-SHELL
      systemctl stop firewalld 2>/dev/null || true
      systemctl disable firewalld 2>/dev/null || true
      systemctl stop iptables 2>/dev/null || true
      systemctl disable iptables 2>/dev/null || true

      yum update -y
      yum install -y curl wget

      while [ ! -f /vagrant/tokens/node-token ]; do
        echo "Waiting for node-token..."
        sleep 5
      done

      TOKEN=$(cat /vagrant/tokens/node-token)
      curl -sfL https://get.k3s.io | K3S_URL=https://192.168.56.10:6443 K3S_TOKEN=$TOKEN sh -

      echo "Agent2 setup complete!"
    SHELL
  end

  config.vm.provision "shell", after: :all, inline: <<-SHELL
    # Ждем пока все ноды поднимутся
    sleep 60

    kubectl label node k3s-server node-role.kubernetes.io/storage=true --overwrite
    kubectl label node k3s-agent1 node-role.kubernetes.io/gpu=true node-role.kubernetes.io/ml=true --overwrite
    kubectl label node k3s-agent2 node-role.kubernetes.io/app=true --overwrite

    # Проверяем ноды
    kubectl get nodes --show-labels

    echo "All nodes labeled successfully!"
  SHELL

  config.vm.synced_folder ".", "/vagrant", type: "rsync"
  config.ssh.insert_key = false
end