Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"
  config.vm.boot_timeout = 600
  config.vm.provider "virtualbox" do |vb|
    vb.cpus = 2
  end

  config.vm.define "k3s-server" do |server|
    server.vm.hostname = "k3s-server"
    server.vm.network "private_network", ip: "192.168.56.10"

    server.vm.network "forwarded_port", guest: 6443, host: 6443
    server.vm.network "forwarded_port", guest: 80, host: 8081
    server.vm.network "forwarded_port", guest: 443, host: 8443
    server.vm.network "forwarded_port", guest: 9090, host: 9091
    server.vm.network "forwarded_port", guest: 3000, host: 3001
    server.vm.network "forwarded_port", guest: 8090, host: 8091

    server.vm.provider "virtualbox" do |vb|
      vb.memory = "4096"
      vb.name = "k3s-server"
    end

    server.vm.disk :disk, size: "50GB", name: "zfs_pool"

    server.vm.provision "shell", inline: <<-SHELL
        ufw disable 2>/dev/null || true

        apt-get update
        apt-get install -y curl wget git

        apt-get install -y zfsutils-linux
        modprobe zfs || true

        zpool create -f \
            -o ashift=12 \
            -O atime=off \
            -O compression=lz4 \
            -O xattr=sa \
            data-pool /dev/sdb || true

        mkdir -p /exports/{nlp_models,nlp_data,localstack_data,postgres_backup,app_static}

        zfs create -o mountpoint=/exports/nlp_models data-pool/nlp-models 2>/dev/null || true
        zfs create -o mountpoint=/exports/nlp_data data-pool/nlp-data 2>/dev/null || true
        zfs create -o mountpoint=/exports/localstack_data data-pool/localstack 2>/dev/null || true
        zfs create -o mountpoint=/exports/postgres_backup data-pool/postgres-backup 2>/dev/null || true
        zfs create -o mountpoint=/exports/app_static data-pool/app-static 2>/dev/null || true

        chmod 777 /exports
        chmod 777 /exports/*

        curl -fsSL https://get.docker.com -o get-docker.sh
        sudo sh get-docker.sh

        sudo usermod -aG docker $USER

        curl -sfL https://get.k3s.io | INSTALL_K3S_EXEC="--disable=traefik" sh -

        echo "Waiting for k3s to be ready..."
        sleep 30

        mkdir -p /vagrant/tokens
        while [ ! -f /var/lib/rancher/k3s/server/node-token ]; do
        echo "Waiting for node-token..."
        sleep 5
        done
        cp /var/lib/rancher/k3s/server/node-token /vagrant/tokens/node-token
        chmod 644 /vagrant/tokens/node-token

        mkdir -p /home/vagrant/.kube
        cp /etc/rancher/k3s/k3s.yaml /home/vagrant/.kube/config
        chown -R vagrant:vagrant /home/vagrant/.kube
        echo "export KUBECONFIG=/home/vagrant/.kube/config" >> /home/vagrant/.bashrc
        echo "export PATH=\$PATH:/usr/local/bin" >> /home/vagrant/.bashrc
        echo "alias k='kubectl'" >> /home/vagrant/.bashrc

        curl -fsSL -o get_helm.sh https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3
        chmod 700 get_helm.sh
        ./get_helm.sh

        echo "Server setup complete!"
    SHELL
  end

  config.vm.define "k3s-agent1" do |agent|
    agent.vm.hostname = "k3s-agent1"
    agent.vm.network "private_network", ip: "192.168.56.11"

    agent.vm.provider "virtualbox" do |vb|
      vb.memory = "4096"
      vb.cpus = 2
      vb.name = "k3s-agent1"
    end

    agent.vm.provision "shell", inline: <<-SHELL
        # Отключаем firewall
        ufw disable 2>/dev/null || true

        apt-get update
        apt-get install -y curl wget

        while [ ! -f /vagrant/tokens/node-token ]; do
        echo "Waiting for node-token..."
        sleep 5
        done

        TOKEN=$(cat /vagrant/tokens/node-token)
        curl -sfL https://get.k3s.io | K3S_URL=https://192.168.56.10:6443 K3S_TOKEN=$TOKEN sh -

        sleep 10

        echo "Agent1 setup complete!"
    SHELL
  end

  config.vm.define "k3s-agent2" do |agent|
    agent.vm.hostname = "k3s-agent2"
    agent.vm.network "private_network", ip: "192.168.56.12"

    agent.vm.provider "virtualbox" do |vb|
      vb.memory = "3072"
      vb.cpus = 1
      vb.name = "k3s-agent2"
    end

    agent.vm.provision "shell", inline: <<-SHELL
        # Отключаем firewall
        ufw disable 2>/dev/null || true

        apt-get update
        apt-get install -y curl wget

        while [ ! -f /vagrant/tokens/node-token ]; do
        echo "Waiting for node-token..."
        sleep 5
        done

        TOKEN=$(cat /vagrant/tokens/node-token)
        curl -sfL https://get.k3s.io | K3S_URL=https://192.168.56.10:6443 K3S_TOKEN=$TOKEN sh -

        # Добавляем небольшую задержку для уверенности
        sleep 10

        echo "Agent2 setup complete!"
    SHELL
  end

    config.vm.provision "shell", after: :all, inline: <<-SHELL
      if [ "$(hostname)" = "k3s-server" ]; then
        echo "Waiting for all nodes to be ready..."
        sleep 90

        export KUBECONFIG=/etc/rancher/k3s/k3s.yaml
        export PATH=$PATH:/usr/local/bin

        while ! kubectl get nodes &>/dev/null; do
          echo "Waiting for kubectl to be ready..."
          sleep 5
        done

        kubectl apply -f https://raw.githubusercontent.com/traefik/traefik/v3.0/docs/content/reference/dynamic-configuration/kubernetes-crd-definition-v1.yml || true

        helm repo add openebs https://openebs.github.io/charts || true
        helm repo update || true
        helm install openebs openebs/openebs \
          --namespace openebs --create-namespace \
          --set zfs-localpv.enabled=true \
          --set zfs-localpv.nodeSelector."kubernetes\.io/hostname"=k3s-server \
          --set localpv.enabled=false \
          --set jiva.enabled=false \
          --set cstor.enabled=false \
          --set mayastor.enabled=false \
          --set ndm.enabled=false || true

        sleep 30

        kubectl patch statefulset -n openebs openebs-zfs-localpv-controller --type=json \
          -p='[{"op": "add", "path": "/spec/template/spec/nodeSelector", "value": {"kubernetes.io/hostname": "k3s-server"}}]' 2>/dev/null || true

        kubectl delete pod -n openebs -l app=openebs-zfs-controller 2>/dev/null || true

        kubectl apply -f https://raw.githubusercontent.com/traefik/traefik/v3.0/docs/content/reference/dynamic-configuration/kubernetes-crd-definition-v1.yml
        kubectl apply -f https://raw.githubusercontent.com/traefik/traefik/v3.0/docs/content/reference/dynamic-configuration/kubernetes-crd-rbac.yml

        helm repo add traefik https://traefik.github.io/charts
        helm install traefik traefik/traefik \
          --namespace kube-system \
          --set ports.web.port=80 \
          --set ports.websecure.port=443

        sleep 60

        kubectl label node k3s-server node-role.kubernetes.io/storage=true --overwrite 2>/dev/null || true
        kubectl label node k3s-agent1 node-role.kubernetes.io/gpu=true node-role.kubernetes.io/ml=true --overwrite 2>/dev/null || true
        kubectl label node k3s-agent2 node-role.kubernetes.io/app=true --overwrite 2>/dev/null || true

        echo ""
        echo "Ноды:"
        kubectl get nodes --show-labels

        echo ""
        echo "OpenEBS поды:"
        kubectl get pods -n openebs
      else
        echo "Skipping cluster setup on agent node"
      fi
    SHELL

  # Используем обычную shared folder вместо rsync
  config.vm.synced_folder ".", "/vagrant"
  config.ssh.insert_key = false
end